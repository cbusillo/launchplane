schema_version = 1

# Stable target ids map only the shared testing and prod lanes.
# PR previews stay outside this catalog because Harbor manages them as
# ephemeral per-PR stacks.

[[targets]]
context = "cm"
instance = "testing"
target_id = "cm-testing-compose-id"

[[targets]]
context = "cm"
instance = "prod"
target_id = "cm-prod-compose-id"

[[targets]]
context = "opw"
instance = "testing"
target_id = "opw-testing-compose-id"

[[targets]]
context = "opw"
instance = "prod"
target_id = "opw-prod-compose-id"
