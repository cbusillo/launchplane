schema_version = 1

# Copy this file to a non-.example path and replace every example-org/... value
# before using it for a real Launchplane service.

[[github_actions]]
repository = "example-org/verireel"
workflow_refs = [
  "example-org/verireel/.github/workflows/preview-control-plane.yml@*",
]
event_names = ["pull_request"]
products = ["verireel"]
contexts = ["verireel-testing"]
actions = ["verireel_preview_refresh.execute", "preview_generation.write"]

[[github_actions]]
repository = "example-org/verireel"
workflow_refs = [
  "example-org/verireel/.github/workflows/preview-cleanup.yml@*",
]
event_names = ["pull_request"]
products = ["verireel"]
contexts = ["verireel-testing"]
actions = ["verireel_preview_destroy.execute", "preview_destroyed.write"]

[[github_actions]]
repository = "example-org/verireel"
workflow_refs = [
  "example-org/verireel/.github/workflows/publish-image.yml@refs/heads/main",
]
event_names = ["push", "workflow_dispatch"]
products = ["verireel"]
contexts = ["verireel"]
actions = ["deployment.write"]

[[github_actions]]
repository = "example-org/verireel"
workflow_refs = [
  "example-org/verireel/.github/workflows/publish-image.yml@refs/heads/main",
]
event_names = ["push", "workflow_dispatch"]
products = ["verireel"]
contexts = ["verireel"]
actions = ["verireel_testing_deploy.execute"]

[[github_actions]]
repository = "example-org/verireel"
workflow_refs = [
  "example-org/verireel/.github/workflows/promote-image.yml@refs/heads/main",
]
event_names = ["workflow_dispatch"]
products = ["verireel"]
contexts = ["verireel"]
actions = ["deployment.write", "backup_gate.write"]

[[github_actions]]
repository = "example-org/verireel"
workflow_refs = [
  "example-org/verireel/.github/workflows/promote-image.yml@refs/heads/main",
]
event_names = ["workflow_dispatch"]
products = ["verireel"]
contexts = ["verireel"]
actions = ["promotion.write", "verireel_prod_deploy.execute", "verireel_prod_promotion.execute", "verireel_prod_rollback.execute"]

[[github_actions]]
repository = "example-org/tenant-opw"
workflow_refs = [
  "example-org/tenant-opw/.github/workflows/launchplane-preview.yml@refs/heads/main",
]
event_names = ["pull_request"]
products = ["odoo"]
contexts = ["opw"]
actions = ["preview_generation.write"]

[[github_actions]]
repository = "example-org/launchplane"
workflow_refs = [
  "example-org/launchplane/.github/workflows/deploy-launchplane.yml@refs/heads/main",
]
event_names = ["workflow_run", "workflow_dispatch"]
products = ["launchplane"]
contexts = ["launchplane"]
actions = ["launchplane_service.read", "launchplane_service_deploy.execute"]
